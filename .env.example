# Blog AutoPost - Environment Variables Configuration
# 環境変数による認証情報設定例
# このファイルをコピーして .env ファイルを作成し、実際の値を設定してください

# X (旧Twitter) 認証情報
X_CONSUMER_KEY=your_consumer_key_here
X_CONSUMER_SECRET=your_consumer_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Bluesky 認証情報
BLUESKY_IDENTIFIER=your_identifier_here
BLUESKY_PASSWORD=your_password_here

# Mastodon 認証情報
MASTODON_INSTANCE_URL=https://mastodon.example
MASTODON_ACCESS_TOKEN=your_access_token_here

# Misskey 認証情報
MISSKEY_INSTANCE_URL=https://misskey.example
MISSKEY_ACCESS_TOKEN=your_access_token_here

# Threads 認証情報
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here
THREADS_ACCESS_TOKEN=your_access_token_here

# 注意事項:
# - 実際の .env ファイルは .gitignore に含められているため、Gitにコミットされません
# - 環境変数が設定されていない場合は、config.yml の値が使用されます
# - セキュリティ強化のため、本番環境では必ず環境変数を使用してください